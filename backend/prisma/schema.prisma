generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {

  id String @id @default(uuid())

  name String

  email String @unique

  password String

  createdAt DateTime @default(now())

  refreshTokens RefreshToken[]

}


model RefreshToken {

  id String @id @default(uuid())

  token String @unique

  userId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

}