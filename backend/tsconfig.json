{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "moduleResolution": "node",

    "resolveJsonModule": true,

    "types": ["node"],

    "sourceMap": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}